# Copy this file to .env and fill in your key. NEVER commit .env.
# Free key: https://console.groq.com  (the only key this project needs)
GROQ_API_KEY=
# Optional: LangSmith tracing (https://smith.langchain.com) to inspect/debug
# every LLM call the agents make. Leave blank to disable.
LANGCHAIN_TRACING_V2=
LANGCHAIN_API_KEY=